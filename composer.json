{
    "name": "martin3r/platform-foodalchemist",
    "description": "Food Alchemist Module for Platform",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Platform Team",
            "email": "team@platform.com"
        }
    ],
    "require": {
        "barryvdh/laravel-dompdf": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "Platform\\FoodAlchemist\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Platform\\FoodAlchemist\\FoodAlchemistServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload-dev": {
        "psr-4": {
            "Platform\\FoodAlchemist\\Tests\\": "tests/"
        }
    }
}
